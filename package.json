{
  "name": "Automation Testing Report",
  "version": "1.0.0",
  "description": "Automation Testing Report",
  "main": "playwright.config.ts",
  "author": "Khanh Do <khanhdo.pmp@gmail.com>",
  "license": "MIT",
  "scripts": {
    "prepare": "husky",
    "allure-generate": "allure generate allure-results",
    "allure-serve": "allure serve allure-results",
    "report": "npm run allure-generate && npm run allure-serve",
    "show-report": "npx playwright show-report",
    "test": "cross-env ENV=qa npx playwright test --project=\"Desktop Chrome\"",
    "posttest": "npm run export:dashboard --silent || true",
    "test:all": "cross-env ENV=qa npx playwright test",
    "posttest:all": "npm run export:dashboard --silent || true",
    "test:chrome": "cross-env ENV=qa npx playwright test --project=\"Desktop Chrome\"",
    "test:firefox": "cross-env ENV=qa npx playwright test --project=\"Desktop Firefox\"",
    "test:webkit": "cross-env ENV=qa npx playwright test --project=\"Desktop Safari\"",
    "codegen": "npx playwright codegen https://ecommerce-playground.lambdatest.io/",
    "test:ui": "cross-env ENV=qa npx playwright test --ui --project=\"Desktop Chrome\"",
    "test:debug": "cross-env ENV=qa npx playwright test --debug --project=\"Desktop Chrome\"",
    "linter": "eslint --ext .ts tests pages locators utilities data --fix",
    "typecheck": "tsc --noEmit",
    "check:all": "npm run linter && npm run typecheck",
    "fetch:defects": "tsx scripts/fetch-defects.ts",
    "export:dashboard": "npm run fetch:defects --silent && tsx scripts/export-dashboard-pdf.ts"
  },
  "keywords": [
    "playwright",
    "typescript",
    "e2e",
    "testing",
    "automation",
    "report"
  ],
  "type": "commonjs",
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.59.1",
    "@types/dotenv": "^6.1.1",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^7.0.4",
    "cross-env": "^10.1.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "uuidv7": "^1.2.1"
  },
  "dependencies": {
    "allure": "^3.7.0",
    "allure-playwright": "^3.7.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.3",
    "nodemailer": "^8.0.5"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --ext .ts tests pages locators utilities data --fix"
    ]
  }
}